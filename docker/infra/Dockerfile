FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    dnsmasq \
    nginx \
    && rm -rf /var/lib/apt/lists/*

# Create config directories
RUN mkdir -p /mnt/infra_config/tftp \
    && mkdir -p /mnt/infra_config/nginx

# Nginx config
COPY docker/infra/nginx.conf /etc/nginx/nginx.conf

# Dnsmasq config - we will point to the shared volume
# generated by the core service.
# For now, we start dnsmasq and nginx.

COPY docker/infra/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
